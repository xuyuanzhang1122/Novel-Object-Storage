# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000
HOST=127.0.0.1

# Public URL (used to generate file URLs)
# Local development example:
BASE_URL=http://127.0.0.1:4000

# Admin credentials (required on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Storage
DATA_DIR=./data
MAX_FILE_SIZE=524288000  # 500MB in bytes

# Session
TOKEN_EXPIRY=604800000   # 7 days in milliseconds

# Cookie security
# Leave unset to auto-detect from BASE_URL, or force true/false when needed.
# COOKIE_SECURE=false
