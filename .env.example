# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000
HOST=127.0.0.1

# Public URL (used to generate file URLs and OpenAPI server URL)
# Accepts either a domain or a raw IP. Examples:
#   BASE_URL=https://storage.example.com
#   BASE_URL=http://203.0.113.42:4000    # public IP, no domain
#   BASE_URL=http://192.168.1.10:4000    # LAN IP
# If unset, the server auto-detects a non-loopback IPv4 on startup.
BASE_URL=http://127.0.0.1:4000

# Admin credentials (required on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Storage
DATA_DIR=./data
MAX_FILE_SIZE=524288000  # 500MB in bytes

# Session
TOKEN_EXPIRY=604800000   # 7 days in milliseconds

# Cookie security
# Leave unset to auto-detect from BASE_URL, or force true/false when needed.
# COOKIE_SECURE=false
